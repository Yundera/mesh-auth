{
  "name": "@aptero/mesh-router-auth",
  "version": "0.1.0",
  "description": "OIDC client registration service for Authelia. Derives client_id from the caller's docker container name via PTR lookup and delegates registration to register-oidc-client.sh.",
  "main": "dist/index.js",
  "type": "module",
  "private": false,
  "scripts": {
    "exec": "concurrently \"tsc && node dist\"",
    "build": "tsc",
    "start": "tsc-watch --onSuccess \"node ./dist\"",
    "test": "tsc && mocha dist/**/*.spec.js",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/chai": "^5.0.1",
    "@types/express": "^5.0.6",
    "@types/mocha": "10.0.10",
    "@types/node": "^22.15.29",
    "chai": "^5.2.0",
    "concurrently": "^9.2.1",
    "eslint": "9.39.2",
    "mocha": "11.7.5",
    "tsc-watch": "^6.2.1"
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
